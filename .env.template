# Graph - Environment Configuration Template
# Copy this file to .env and fill in your values

# Embedding API Configuration
# Required: API key from Voyage AI or OpenAI
GRAPH_EMBEDDING_API_KEY=your_api_key_here

# Embedding Provider: "voyage" or "openai"
GRAPH_EMBEDDING_PROVIDER=voyage

# Embedding Model
# For Voyage: voyage-3-lite (default), voyage-3, etc.
# For OpenAI: text-embedding-3-small (default), text-embedding-3-large, etc.
GRAPH_EMBEDDING_MODEL=voyage-3-lite

# Database location (optional)
# GRAPH_DATABASE_URL=graph.db

# Sibling project database paths (optional)
# GRAPH_FORTY_TWO_DB=/path/to/forty-two/forty_two.db
# GRAPH_MAX_DB=/path/to/max/max.db
# GRAPH_PRESENCE_DB=/path/to/presence/presence.db
# GRAPH_ME_CONFIG=/path/to/me/config/projects.yaml
# GRAPH_KINDLE_DB=/path/to/supabooks/supabooks.db

# Content filtering (optional)
# GRAPH_CONTENT_MIN_SCORE=7.0
